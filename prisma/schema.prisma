//mesmo se parecendo com o prisma de todas as empresas esse sera o master

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ROLE {
  GOD // USUARIO COM PODERES DE DEUS NO SISTEMA
  ADMIN
  GESTOR
  ATENDENTE
}

enum modulo{
  OFICINA
  CORPORATIVO
  EVENTOS
}

// prisma/schema.prisma
model empresa {
  id              String    @id @default(uuid())
  nome            String    @unique
  cnpj            String    @unique
  setores         String[]
  logoUrl         String?                    // URL da logo da empresa
  botName         String?                    // Nome do assistente virtual para esta empresa
  botPresentation String?                    // Input: como o bot deve se apresentar
  botServiceDesc  String?                    // Input: como o bot deve atender
  botAvisosDesc   String?                    // Input: como apresentar os avisos
  botPrompt       String?                    // Prompt consolidado gerado pela OpenAI
  users           User[]
  chamados        Chamado[]
  cpfs            cpfs[]
  avisos          avisos[]
  modulos         modulo[]
  databaseUrl     String? // URL de conexão específica para esta empresa
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([nome])
  @@index([cnpj])
}

//não precisa relacionar com os usuarios porque vai ser um banco por empresa
model User {
  id        String    @id @default(uuid())
  empresaId String
  Empresa   empresa   @relation(fields: [empresaId], references: [id])
  email     String    @unique
  cpf       String    @unique
  name      String
  role      ROLE
  avatarUrl String?
  setor     String
  resumo    String?
  password  String
  chamados  Chamado[] @relation("AtendenteChamados")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([empresaId])
  @@index([cpf])
  @@index([email])
}

model Chamado {
  id          String   @id @default(uuid())
  Empresa     empresa  @relation(fields: [empresaId], references: [id])
  empresaId   String
  ticket      String   @unique
  nome        String
  cpf         String
  setor       String
  descricao   String
  historico   String?
  status      String   @default("NOVO")
  prioridade  String   @default("normal")
  anexoUrl    String?
  atendenteId String?
  atendente   User?    @relation("AtendenteChamados", fields: [atendenteId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([empresaId])
  @@index([cpf])
  @@index([status])
  @@index([empresaId, status])
  @@index([ticket])
}

// Modelo para armazenar CPFs e nomes dos usuários autorizados a usar o chatbot
model cpfs {
  id        String   @id @default(uuid())
  cpf       String   @unique
  empresaId String
  Empresa   empresa  @relation(fields: [empresaId], references: [id])
  nome      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empresaId])
  @@index([cpf])
}

//para gerar os dashboards de chamados fechados, para não poluir a tabela principal
model tickets_fechados {
  id         String   @id @default(uuid())
  ticket     String   @unique
  nome       String
  cpf        String
  setor      String
  historico  String?
  prioridade String
  anexoUrl   String?
  atendente  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([cpf])
  @@index([ticket])
}

//representa o quadro de avisos da empresa
model avisos {
  id         String    @id @default(uuid())
  empresaId  String
  Empresa    empresa   @relation(fields: [empresaId], references: [id])
  titulo     String
  prompt_bot String?
  nome_bot   String?
  conteudo   String
  setor      String?
  duracao    String?
  logoUrl    String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([empresaId])
  @@index([setor])
}



model resumoPersona {
  id        String   @id @default(uuid())
  cpf       String   @unique
  nome      String
  resumo    String //resumo da persona gerado pelo gpt, para ele se lembrar da personalidade do usuário
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cpf])
}

model cpfsLeads{
  id        String   @id @default(uuid())
  cpf       String   @unique
  nome      String
  telefone  String
  empresa   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cpf])
  @@index([telefone])
}

model logs_de_acesso{
  id        String   @id @default(uuid())
  cpf       String?
  nome      String?
  empresa   String
  modulo    modulo
  acao      String //ex: "login", "criou chamado", "fechou chamado", etc.
  createdAt DateTime @default(now())

  @@index([cpf])
  @@index([empresa])
  @@index([modulo]) 
}