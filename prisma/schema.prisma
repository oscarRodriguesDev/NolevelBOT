generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model empresa {
  id              String    @id @default(uuid())
  nome            String    @unique
  cnpj            String    @unique
  setores         String[]
  databaseUrl     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  botAvisosDesc   String?
  botName         String?
  botPresentation String?
  botPrompt       String?
  botServiceDesc  String?
  logoUrl         String?
  modulos         modulo[]
  chamados        Chamado[]
  users           User[]
  avisos          avisos[]
  cpfs            cpfs[]

  @@index([nome])
  @@index([cnpj])
}

model User {
  id        String    @id @default(uuid())
  empresaId String
  email     String    @unique
  cpf       String    @unique
  name      String
  role      ROLE
  avatarUrl String?
  setor     String
  resumo    String?
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  chamados  Chamado[] @relation("AtendenteChamados")
  Empresa   empresa   @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@index([cpf])
  @@index([email])
}

model Chamado {
  id          String   @id @default(uuid())
  ticket      String   @unique
  nome        String
  cpf         String
  setor       String
  descricao   String
  historico   String?
  status      String   @default("NOVO")
  prioridade  String   @default("normal")
  anexoUrl    String?
  atendenteId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  empresaId   String
  atendente   User?    @relation("AtendenteChamados", fields: [atendenteId], references: [id])
  Empresa     empresa  @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@index([cpf])
  @@index([status])
  @@index([empresaId, status])
  @@index([ticket])
}

model cpfs {
  id        String   @id @default(uuid())
  cpf       String   @unique
  nome      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  empresaId String
  telefone  String?
  Empresa   empresa  @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@index([cpf])
}

model tickets_fechados {
  id         String   @id @default(uuid())
  ticket     String   @unique
  nome       String
  cpf        String
  setor      String
  historico  String?
  prioridade String
  anexoUrl   String?
  atendente  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([cpf])
  @@index([ticket])
}

model avisos {
  id         String    @id @default(uuid())
  titulo     String
  conteudo   String
  setor      String?
  duracao    String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  empresaId  String
  nome_bot   String?
  prompt_bot String?
  logoUrl    String?
  Empresa    empresa   @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@index([setor])
}

model resumoPersona {
  id        String   @id @default(uuid())
  cpf       String   @unique
  nome      String
  resumo    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cpf])
}

model cpfsLeads {
  id        String   @id @default(uuid())
  cpf       String   @unique
  nome      String
  empresa   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  telefone  String

  @@index([cpf])
  @@index([telefone])
}

model logs_de_acesso {
  id        String   @id @default(uuid())
  cpf       String?
  nome      String?
  empresa   String
  modulo    modulo
  acao      String
  createdAt DateTime @default(now())

  @@index([cpf])
  @@index([empresa])
  @@index([modulo])
}

model cache {
  key       String   @id
  value     String
  expiresAt DateTime
}

model tickets_evitados {
  id         String   @id
  nome       String
  empresaId  String
  cpf        String
  setor      String
  descricao  String
  prioridade String
  anexoUrl   String?
  atendente  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
}

enum ROLE {
  GOD
  ADMIN
  GESTOR
  ATENDENTE
}

enum modulo {
  OFICINA
  CORPORATIVO
  EVENTOS
}
