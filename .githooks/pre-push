#!/bin/sh
# Bloqueia push da branch 'testes' para remote refs que não sejam 'testes'

PROTECTED="testes"
CURRENT=$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')

[ "$CURRENT" != "$PROTECTED" ] && exit 0

while read LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
  REMOTE_BRANCH=$(echo "$REMOTE_REF" | sed 's|refs/heads/||')
  if [ "$REMOTE_BRANCH" != "$PROTECTED" ]; then
    echo "==========================================="
    echo "  BLOQUEADO: push de '$PROTECTED' para '$REMOTE_BRANCH'"
    echo ""
    echo "  A branch '$PROTECTED' só pode ser enviada para"
    echo "  'origin/$PROTECTED'."
    echo "  Use: git push origin $PROTECTED:$PROTECTED"
    echo "==========================================="
    exit 1
  fi
done

exit 0
